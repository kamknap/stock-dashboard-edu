# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).

# ---- Server ----
ENVIRONMENT=development
PORT=8080
# Comma-separated list of allowed CORS origins (frontend URLs).
# Firebase Hosting serves the project on both *.web.app and *.firebaseapp.com.
ALLOWED_ORIGINS=http://localhost:5173,https://stock-dashboard-edu.web.app,https://stock-dashboard-edu.firebaseapp.com

# ---- Scheduler protection ----
# Shared secret sent by the GitHub Actions cron in the X-Scheduler-Secret header.
# Generate a strong value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
RUN_ANALYSIS_SECRET=change-me

# ---- LLM (Gemini, Google AI Studio) ----
GEMINI_API_KEY=

# ---- Market data ----
# Yahoo Finance is keyless. These stay empty unless you wire optional fallbacks.
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=

# ---- Persistence: Firebase Realtime Database (Spark, no billing card) ----
# Path to a service-account JSON key (Project settings -> Service accounts).
GOOGLE_APPLICATION_CREDENTIALS=
# Realtime Database URL, e.g. https://stock-dashboard-edu-default-rtdb.europe-west1.firebasedatabase.app
FIREBASE_DB_URL=
GCP_PROJECT_ID=stock-dashboard-edu
